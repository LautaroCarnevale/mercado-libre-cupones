# Variables inyectadas en build-time por Vite/esbuild.
# NO ocultan secretos: todo lo que va al bundle es visible.
# Para credenciales sensibles, usar un backend proxy.

# URL base de la API de cupones
VITE_API_BASE_URL=http://localhost:3000/api

# Timeout de requests en milisegundos
VITE_API_TIMEOUT=10000

# Target browser: chrome | firefox
BROWSER=chrome
